enable
configure terminal
hostname R1-TELCONET

interface Loopback0
 ip address 3.3.3.1 255.255.255.255
 no shutdown
 exit

! Conexión a R1-MATRIZ (e0/3 de Matriz)
interface Ethernet0/0
 description HACIA R1-MATRIZ
 ip address 200.2.2.1 255.255.255.252
 no shutdown
 exit

! Conexión a R2-TELCONET (e0/0 de R2)
interface Ethernet0/1
 description HACIA R2-TELCONET
 ip address 200.2.1.1 255.255.255.252
 no shutdown
 exit

router ospf 1
 network 200.2.1.0 0.0.0.3 area 0
 network 3.3.3.1 0.0.0.0 area 0
 exit

router bgp 300
 bgp log-neighbor-changes
 neighbor 200.2.2.2 remote-as 100
 neighbor 3.3.3.2 remote-as 300
 neighbor 3.3.3.2 update-source Loopback0
 neighbor 3.3.3.2 next-hop-self
 neighbor 3.3.3.3 remote-as 300
 neighbor 3.3.3.3 update-source Loopback0
 neighbor 3.3.3.3 next-hop-self
 exit
end
write memory