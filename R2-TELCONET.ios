enable
configure terminal
hostname R2-TELCONET

interface Loopback0
 ip address 3.3.3.2 255.255.255.255
 no shutdown
 exit

! Viene de R1-TELCONET (e0/1 de R1)
interface Ethernet0/0
 description HACIA R1-TELCONET
 ip address 200.2.1.2 255.255.255.252
 no shutdown
 exit

! Conexión a R3-TELCONET (e0/2 de R3)
interface Ethernet0/1
 description HACIA R3-TELCONET
 ip address 200.2.1.5 255.255.255.252
 no shutdown
 exit

router ospf 1
 network 200.2.1.0 0.0.0.3 area 0
 network 200.2.1.4 0.0.0.3 area 0
 network 3.3.3.2 0.0.0.0 area 0
 exit

router bgp 300
 bgp log-neighbor-changes
 neighbor 3.3.3.1 remote-as 300
 neighbor 3.3.3.1 update-source Loopback0
 neighbor 3.3.3.3 remote-as 300
 neighbor 3.3.3.3 update-source Loopback0
 exit
end
write memory