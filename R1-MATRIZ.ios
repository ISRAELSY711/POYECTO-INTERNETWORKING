enable
configure terminal
hostname R1-MATRIZ

! --- 1. CONFIGURACION DE INTERFACES LAN
interface Ethernet0/0
 description L3_A_MLS1_MATRIZ_E1_0
 ip address 10.255.255.2 255.255.255.252
 no shutdown
exit

interface Ethernet0/1
 description L3_A_MLS2_MATRIZ_E1_0
 ip address 10.255.255.6 255.255.255.252
 no shutdown
 exit

! --- 2. CONFIGURACION DE INTERFACES WAN
interface Ethernet0/2
 description WAN_A_CNT_PE1
 ip address 200.1.2.2 255.255.255.252
 no shutdown

interface Ethernet0/3
 description WAN_A_TELCONET_PE1
 ip address 200.2.2.2 255.255.255.252
 no shutdown

! --- 3. ENRITAMIENTO OSPF
router ospf 1
 router-id 3.3.3.3
 passive-interface default
 no passive-interface Ethernet0/0
 no passive-interface Ethernet0/1
 network 10.255.255.0 0.0.0.3 area 0
 network 10.255.255.4 0.0.0.3 area 0
 default-information originate always metric 10
 redistribute bgp 100 subnets
 exit
router bgp 100
 bgp router-id 3.3.3.3
 bgp log-neighbor-changes
 neighbor 200.1.2.1 remote-as 200
 neighbor 200.2.2.1 remote-as 300
 ! Inyectamos las subredes de OSPF hacia los ISPs
 redistribute ospf 1 match internal external 1 external 2
 exit

end
write memory