enable
configure terminal
hostname R1-MATRIZ

! --- INTERFACES ---
interface ethernet 0/2
 description LINK_HACIA_MLS1_ACTIVO
 ip address 10.255.0.1 255.255.255.252
 ip nat inside
 no shutdown
exit

interface ethernet 0/3
 description LINK_HACIA_MLS2_STANDBY
 ip address 10.255.0.5 255.255.255.252
 ip nat inside
 no shutdown
exit

interface ethernet 0/0
 description CONEXION_ISP1_CNT_PRINCIPAL
 ip address 200.1.2.2 255.255.255.252
 ip nat outside
 no shutdown
exit

interface ethernet 0/1
 description CONEXION_ISP2_TELCONET_BACKUP
 ip address 200.2.2.2 255.255.255.252
 ip nat outside
 no shutdown
exit

! --- RUTAS ESTÁTICAS DE RESPALDO HACIA MLS ---
ip route 10.10.0.0 255.255.252.0 10.255.0.2
ip route 10.10.0.0 255.255.252.0 10.255.0.6 5

! --- eBGP CON ISP1 (Principal) ---
router bgp 65001
 network 10.10.0.0 mask 255.255.252.0
 neighbor 200.1.2.1 remote-as 64500
 neighbor 200.1.2.1 description ISP1_CNT_PRINCIPAL
 neighbor 200.1.2.1 ebgp-multihop 1
 neighbor 200.1.2.1 timers 10 30 30
 default-information originate
 exit

! --- eBGP CON ISP2 (Backup con local-pref menor) ---
router bgp 65001
 neighbor 200.2.2.1 remote-as 64501
 neighbor 200.2.2.1 description ISP2_TELCONET_BACKUP
 neighbor 200.2.2.1 ebgp-multihop 1
 neighbor 200.2.2.1 timers 10 30 30
 !
 ! Prefijo local más bajo para que sea backup
 neighbor 200.2.2.1 route-map SET-LOCAL-PREF in
 exit

! Route-map para dar menor prioridad a ISP2
route-map SET-LOCAL-PREF permit 10
 set local-preference 50
exit

! --- NAT DUAL CON ROUTE-MAPS (Configuración GLOBAL, no en interfaz) ---
access-list 1 permit 10.10.0.0 0.0.3.255

! Route-maps para NAT
route-map NAT-ISP1 permit 10
 match ip address 1

route-map NAT-ISP2 permit 10
 match ip address 1

! NAT GLOBAL (así se configura correctamente)
ip nat inside source route-map NAT-ISP1 interface ethernet 0/0 overload
ip nat inside source route-map NAT-ISP2 interface ethernet 0/1 overload

! --- OSPF hacia MLS (para redistribuir default route) ---
router ospf 1
 router-id 3.3.3.3
 network 10.255.0.0 0.0.0.7 area 0
 default-information originate always
 ! Redistribuir rutas aprendidas por BGP
 redistribute bgp 65001 subnets
exit

! --- Redistribuir OSPF dentro de BGP ---
router bgp 65001
 redistribute ospf 1 match internal external 1 external 2
exit

do write