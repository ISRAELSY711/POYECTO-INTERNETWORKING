enable
configure terminal
hostname R1-CNT

interface Loopback0
 ip address 2.2.2.1 255.255.255.255
 no shutdown
 exit

! Conexión a R1-MATRIZ (e0/2 de Matriz)
interface Ethernet0/0
 description HACIA R1-MATRIZ
 ip address 200.1.2.1 255.255.255.252
 no shutdown
 exit

! Conexión a R2-CNT (e0/0 de R2)
interface Ethernet0/1
 description HACIA R2-CNT
 ip address 200.1.1.1 255.255.255.252
 no shutdown
 exit

router ospf 1
 network 200.1.1.0 0.0.0.3 area 0
 network 2.2.2.1 0.0.0.0 area 0
 exit

router bgp 200
 bgp log-neighbor-changes
 neighbor 200.1.2.2 remote-as 100
 neighbor 2.2.2.2 remote-as 200
 neighbor 2.2.2.2 update-source Loopback0
 neighbor 2.2.2.2 next-hop-self
 neighbor 2.2.2.3 remote-as 200
 neighbor 2.2.2.3 update-source Loopback0
 neighbor 2.2.2.3 next-hop-self
 exit
end
write memory